{
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./build",

    "module": "nodenext",
    "target": "esnext",

    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
  },
  "include": ["src/"],
  "exclude": ["src/electron"]
}
